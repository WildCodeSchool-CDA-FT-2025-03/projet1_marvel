{
  "name": "marvel-project",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint:client": "cd client && npm run lint",
    "lint:server": "cd server && npm run lint",
    "format:client": "cd client && npm run format",
    "format:server": "cd server && npm run format",
    "check": "npm run lint:client && npm run lint:server && npm run format:client && npm run format:server",
    "dev": "concurrently -n \"client,server\" -c \"cyan.bold,green.bold\" \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev"
  },
  "lint-staged": {
    "client/**/*.{js,jsx,ts,tsx}": [
      "npm --prefix client run lint:fix",
      "npm --prefix client run format:fix"
    ],
    "server/**/*.{js,ts,mjs}": [
      "npm --prefix server run lint:fix",
      "npm --prefix server run format:fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.0.0"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-toast": "^1.2.7",
    "framer-motion": "^12.6.3",
    "lucide-react": "^0.487.0"
  }
}
